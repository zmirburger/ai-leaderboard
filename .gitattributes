# Force LF line endings on all text files.
# Prevents Windows Git autocrlf from converting LF→CRLF on checkout,
# which was the root cause of the data.json truncation gremlins.

* text=auto eol=lf

*.py   text eol=lf
*.json text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.txt  text eol=lf

# Binary
*.png binary
*.ico binary
